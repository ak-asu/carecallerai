CUSTOM_STT_URL=

HF_TOKEN=

# App URL for Vapi custom LLM callback (no trailing slash)
# Local: http://localhost:3000  Production: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AssemblyAI
ASSEMBLYAI_API_KEY=

# ElevenLabs
ELEVENLABS_API_KEY=

# Groq
GROQ_API_KEY=

# Gemini
GEMINI_API_KEY=

# Supermemory
SUPERMEMORY_API_KEY=

# Tavily
